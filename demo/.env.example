# webmap_ai demo – optional environment variables
# Copy this file to .env and fill in your values.
#
# The assistant will use the first configured option it finds, in this order:
#   1. VITE_BACKEND_URL  – FastAPI backend (recommended; supports OpenAI & Anthropic)
#   2. VITE_OPENROUTER_API_KEY  – direct OpenRouter call from the browser
#   3. Neither set  – mock responses (still runs through MapAssistantRouter)

# --- FastAPI backend (see backend/ in the repo root) ---
# Start the backend with: uvicorn backend.main:app --reload
# Then set this to the backend URL (no trailing slash).
# VITE_BACKEND_URL=http://localhost:8000

# --- OpenRouter API key (optional, browser-side fallback) ---
# Get your key at https://openrouter.ai/keys
# VITE_OPENROUTER_API_KEY=sk-or-...
