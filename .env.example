# webmap_ai backend – required environment variables
# Copy this file to .env and fill in your values.

# --- LLM provider selection ---
# Supported values: openai, anthropic, openrouter  (default: openai)
LLM_PROVIDER=openai

# --- OpenAI (required when LLM_PROVIDER=openai) ---
OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini   # optional, this is the default

# --- OpenRouter (required when LLM_PROVIDER=openrouter) ---
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=openai/gpt-4o-mini   # optional, this is the default

# --- Anthropic (required when LLM_PROVIDER=anthropic) ---
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-haiku-latest   # optional, this is the default
