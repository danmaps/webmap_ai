{
  "name": "webmap_ai",
  "version": "0.1.2",
  "description": "Provider-neutral AI assistant infrastructure for web maps.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run test",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danmaps/webmap_ai.git"
  },
  "keywords": [
    "maps",
    "llm",
    "assistant",
    "typescript"
  ],
  "author": "Danny McVey <dannybmcvey@gmail.com> (https://github.com/danmaps)",
  "license": "ISC",
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/danmaps/webmap_ai/issues"
  },
  "homepage": "https://github.com/danmaps/webmap_ai#readme",
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
